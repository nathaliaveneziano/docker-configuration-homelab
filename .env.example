# ==========================================
# 🌐 REDE, CONECTIVIDADE E DOMÍNIO
# ==========================================
NETWORK_NAME=network_name
NETWORK_SUBNET=127.0.0.0/24
NETWORK_GATEWAY=127.0.0.1
DOMAIN_NAME=localhost

# ==========================================
# 🌍 CONFIGURAÇÕES REGIONAIS
# ==========================================
TIMEZONE=America/Sao_Paulo
LOCALE=pt_BR.UTF-8

# ==========================================
# 👤 USUÁRIO E PERMISSÕES
# ==========================================
# Use: id -u e id -g no Linux/WSL para obter seus valores
PUID=1000
PGID=1000

# ==========================================
# 💾 CAMINHOS DE ARMAZENAMENTO
# ==========================================
# SSD (256GB) - Para dados que exigem velocidade (DBs, configs)
SSD_PATH=/home/usuario/docker-configuration

# HDD (1TB) - Para dados grandes (backups, mídia, logs)
HDD_PATH=/mnt/hdd/docker-configuration

# ==========================================
# 🌐 NGINX PROXY MANAGER
# ==========================================
NPM_PORT=81
NPM_CONTAINER=nginx-proxy-manager
NPM_LIMITS_MEMORY=256M
NPM_LIMITS_CPUS=0.5
NPM_RESERVATIONS_MEMORY=64M
NPM_INTERVAL=60
NPM_TIMEOUT=10
NPM_RETRIES=3
NPM_START_PERIOD=30
# NGINX Proxy Manager (login inicial: admin@example.com / changeme)
NPM_ADMIN_EMAIL=admin@seu-dominio.com

# ==========================================
# 📧 NOTIFICAÇÕES (Opcional)
# ==========================================
SMTP_HOST=smtp.seu-dominio.com
SMTP_PORT=587
SMTP_ADMIN_EMAIL=email@gmail.com
SMTP_USER=email@seu-dominio.com
SMTP_PASSWORD=SMTPPass
SMTP_FROM=noreply@eu-dominio.com

# ==========================================
# 🔄 BACKUP
# ==========================================
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *
BACKUP_DESTINATION=/mnt/d/docker-backups
BACKUP_SPLIT=false  # true = backup individual por database